// Chiro City Housing & Rental Management — database schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  HOUSING_OFFICER
}

enum PropertyType {
  residential
  commercial
}

enum PropertyStatus {
  available
  rented
  sold
  maintenance
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(HOUSING_OFFICER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Property {
  id          String         @id @default(uuid())
  code        String         @unique
  type        PropertyType
  woreda      String
  kebele      String
  houseNumber String         @map("house_number")
  rooms       Int
  area        Decimal        @db.Decimal(12, 2)
  condition   String
  status      PropertyStatus @default(available)
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  rentals Rental[]
  sales   Sale[]
}

model Tenant {
  id         String   @id @default(uuid())
  fullName   String   @map("full_name")
  gender     String
  phone      String
  nationalId String?  @unique @map("national_id")
  familySize Int      @map("family_size")
  status     String   @default("active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  rentals   Rental[]
  purchases Sale[]   @relation("BuyerSales")
}

model Rental {
  id          String   @id @default(uuid())
  propertyId  String   @map("property_id")
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  monthlyRent Decimal  @map("monthly_rent") @db.Decimal(12, 2)
  dueDay      Int      @map("due_day")
  deposit     Decimal? @db.Decimal(12, 2)
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  payments RentalPayment[]
}

model RentalPayment {
  id        String   @id @default(uuid())
  rentalId  String   @map("rental_id")
  rental    Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @map("paid_at")
  method    String
  receiptNo String?  @map("receipt_no")
  createdAt DateTime @default(now()) @map("created_at")
}

model Sale {
  id             String   @id @default(uuid())
  propertyId     String   @map("property_id")
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  buyerId        String   @map("buyer_id")
  buyer          Tenant   @relation("BuyerSales", fields: [buyerId], references: [id], onDelete: Restrict)
  totalPrice     Decimal  @map("total_price") @db.Decimal(14, 2)
  downPayment    Decimal  @map("down_payment") @db.Decimal(14, 2)
  durationMonths Int      @map("duration_months")
  startDate      DateTime @map("start_date")
  status         String   @default("active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  payments SalePayment[]
}

model SalePayment {
  id        String   @id @default(uuid())
  saleId    String   @map("sale_id")
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(14, 2)
  paidAt    DateTime @map("paid_at")
  method    String
  createdAt DateTime @default(now()) @map("created_at")
}

/// Optional audit trail for sensitive actions
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
}
